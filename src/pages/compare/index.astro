---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/Base.astro";

const entries = await getCollection("compare");
entries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Compare Tools" description="Side-by-side SaaS and software comparisons. Independent, data-driven, always up-to-date.">
  <div style="max-width:760px;margin:0 auto;padding:2rem 1rem;">
    <h1 style="font-size:2rem;margin-bottom:1rem;">Compare Tools</h1>
    <p style="font-size:1.05rem;color:#666;margin-bottom:2rem;">Independent, side-by-side comparisons of software & SaaS. Every comparison is based on publicly verifiable data and updated quarterly.</p>
    <div style="display:flex;flex-direction:column;gap:1rem;">
      {entries.map((entry) => (
        <a href={`/compare/${entry.slug}/`} style="border:1px solid #e5e7eb;border-radius:8px;padding:1.25rem;text-decoration:none;color:inherit;transition:box-shadow 0.15s,border-color 0.15s;">
          <time datetime={entry.data.date.toISOString()} style="font-size:0.8rem;color:#2563eb;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">{entry.data.date.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}</time>
          <h2 style="font-size:1.15rem;margin:0.5rem 0 0.25rem;color:#111;">{entry.data.title}</h2>
          {entry.data.description && <p style="font-size:0.95rem;color:#666;margin:0;">{entry.data.description}</p>}
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  a:hover { border-color: #2563eb; box-shadow: 0 2px 12px rgba(37,99,235,0.1); text-decoration: none; }
</style>
