---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/Base.astro";

const entries = await getCollection("best");
entries.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="Best-Of Guides" description="Curated guides to the best SaaS and software for every use case and budget.">
  <div style="max-width:760px;margin:0 auto;padding:2rem 1rem;">
    <h1 style="font-size:2rem;margin-bottom:1rem;">Best-Of Guides</h1>
    <p style="font-size:1.05rem;color:#666;margin-bottom:2rem;">Curated guides to the best software for specific use cases, budgets, and team sizes. Every recommendation backed by data.</p>
    <div style="display:flex;flex-direction:column;gap:1rem;">
      {entries.map((entry) => (
        <a href={`/best/${entry.slug}/`} style="border:1px solid #e5e7eb;border-radius:8px;padding:1.25rem;text-decoration:none;color:inherit;transition:box-shadow 0.15s,border-color 0.15s;">
          <time datetime={entry.data.date.toISOString()} style="font-size:0.8rem;color:#2563eb;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;">{entry.data.date.toLocaleDateString("en-US", { month: "long", day: "numeric", year: "numeric" })}</time>
          <h2 style="font-size:1.15rem;margin:0.5rem 0 0.25rem;color:#111;">{entry.data.title}</h2>
          {entry.data.description && <p style="font-size:0.95rem;color:#666;margin:0;">{entry.data.description}</p>}
        </a>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  a:hover { border-color: #2563eb; box-shadow: 0 2px 12px rgba(37,99,235,0.1); text-decoration: none; }
</style>
